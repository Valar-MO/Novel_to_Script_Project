# LLM provider:
# deepseek = DeepSeek API
# cloud_api = OpenAI-compatible API
# mock = unit tests / local demo without real model calls
LLM_PROVIDER=deepseek

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# OpenAI-compatible API aliases, optional
LLM_API_KEY=
LLM_API_BASE_URL=
LLM_API_MODEL=

# Generation settings
LLM_TEMPERATURE=0
LLM_API_TIMEOUT_SECONDS=180
LLM_API_THINKING_ENABLED=false
LLM_API_REASONING_EFFORT=
