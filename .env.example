# LLM provider:
# ollama = 本地 Ollama
# mock = 单元测试使用固定结果
# cloud_api = 后续云端 API 预留
LLM_PROVIDER=ollama

# Ollama local service
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=180

# Generation settings
LLM_TEMPERATURE=0
LLM_KEEP_ALIVE=10m

# Future cloud API
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_API_MODEL=